{
  "rules": {
    "rooms": {
      "$code": {
        ".read": "auth != null",

        "meta": {
          ".write": "auth != null && ( !data.exists() || data.parent().child('host/uid').val() === auth.uid || data.parent().child('guest/uid').val() === auth.uid || newData.parent().child('guest/uid').val() === auth.uid || data.child('hostUid').val() === auth.uid || newData.child('hostUid').val() === auth.uid )",
          ".validate": "newData.hasChildren(['status', 'createdAt'])"
        },

        "host": {
          ".write": "auth != null && ( !data.exists() || data.child('uid').val() === auth.uid )",
          ".validate": "newData.hasChildren(['deviceId', 'nickname', 'uid']) && newData.child('uid').val() === auth.uid"
        },

        "guest": {
          ".write": "auth != null && ( !data.exists() || data.child('uid').val() === auth.uid )",
          ".validate": "newData.hasChildren(['deviceId', 'nickname', 'uid']) && newData.child('uid').val() === auth.uid"
        },

        "players": {
          "$pid": {
            ".write": "auth != null && ( !data.exists() || data.child('uid').val() === auth.uid )",
            ".validate": "newData.hasChildren(['deviceId', 'nickname', 'uid']) && newData.child('uid').val() === auth.uid"
          }
        },

        "messages": {
          "$msgId": {
            ".write": "auth != null && newData.exists() && ( root.child('rooms').child($code).child('host/uid').val() === auth.uid || root.child('rooms').child($code).child('guest/uid').val() === auth.uid || root.child('rooms').child($code).child('players').child(newData.child('from').val()).child('uid').val() === auth.uid )",
            ".validate": "newData.hasChildren(['from', 'type', 'ts']) && newData.child('from').isString() && newData.child('from').val().length <= 64 && ( newData.child('from').val() === root.child('rooms').child($code).child('host/deviceId').val() || newData.child('from').val() === root.child('rooms').child($code).child('guest/deviceId').val() || root.child('rooms').child($code).child('players').child(newData.child('from').val()).exists() )"
          }
        }
      }
    }
  }
}
